# ─── Database (NeonDB) ─────────────────────────────────────────────────────────
# Get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── BetterAuth ────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -hex 32
BETTER_AUTH_SECRET="your-secret-here"

# Web app (apps/web) — client-facing
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Admin app (apps/admin) — set these in apps/admin/.env.local
# BETTER_AUTH_URL="http://localhost:3001"
# NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3001"

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Get your webhook secret from https://dashboard.stripe.com/webhooks
# For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Email (for magic link) ────────────────────────────────────────────────────
# Option A: SMTP (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Flow Massage <hello@flowmassage.com>"

# Option B: Resend
# RESEND_API_KEY="re_..."

# ─── Admin / Internal ──────────────────────────────────────────────────────────
# URL of the web app — used by admin to send magic links to clients
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
